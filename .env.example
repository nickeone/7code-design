# ─────────────────────────────────────────────────────────────────────────────
# 7code.tech — environment variables
# Copy to .env.local for local dev (vercel dev reads it automatically).
# Set all of these in the Vercel project dashboard → Settings → Environment Variables.
# NEVER commit real values.
# ─────────────────────────────────────────────────────────────────────────────

# Shared secret that authenticates Formspree webhooks.
# Append as a query param to your webhook URL:
#   https://www.7code.tech/api/lead-enrich?secret=<value>
# Generate with: openssl rand -hex 32
FORMSPREE_WEBHOOK_SECRET=replace_with_a_random_secret

# Apollo.io API key — create at https://app.apollo.io/#/settings/integrations/api
# Needs "People → Match" and "Organizations → Enrich" permissions.
APOLLO_API_KEY=replace_with_apollo_api_key

# Resend transactional email API key — create at https://resend.com/api-keys
# The sending domain (leads@7code.tech) must be verified in Resend.
RESEND_API_KEY=re_replace_with_resend_api_key

# Recipient for enriched lead notifications.
LEAD_NOTIFY_TO=office@7code.ro
